{
  "name": "@tramber/server",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "tramber-server": "./bin/server.js"
  },
  "files": [
    "dist",
    "src",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node ./dist/server.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "@tramber/agent": "workspace:*",
    "@tramber/sdk": "workspace:*",
    "@tramber/shared": "workspace:*",
    "fastify": "^5.3.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@types/ws": "^8.5.10",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
