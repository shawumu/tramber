{
  "$schema": "https://tramber.dev/schema/settings.json",
  "apiKey": "${ANTHROPIC_AUTH_TOKEN}",
  "baseURL": "${ANTHROPIC_BASE_URL}",
  "model": "${ANTHROPIC_MODEL:glm-4.7}",
  "provider": "anthropic",
  "scene": "coding",
  "maxIterations": 10,
  "enableExperience": true,
  "enableRoutine": true,
  "server": {
    "host": "localhost",
    "port": 3000
  },
  "scenes": {
    "default": "coding",
    "available": ["coding"]
  },
  "routine": {
    "autoCreate": true,
    "minSuccessRate": 0.8,
    "minExecutions": 3,
    "minSuccessCount": 3
  },
  "plugins": {
    "builtin": [],
    "community": []
  },
  "checkpoint": {
    "enabled": false,
    "maxSnapshots": 100
  },
  "experience": {
    "storage": "file",
    "retentionDays": 30,
    "autoRecord": true
  },
  "toolPermissions": {
    "file_read": true,
    "file_write": "confirm",
    "file_delete": false,
    "command_execute": ["npm", "git", "ls", "cat", "grep", "find"],
    "command_dangerous": "deny"
  },
  "sandbox": {
    "enabled": true,
    "allowedPaths": ["./"],
    "deniedPaths": ["~/.ssh", "~/.aws", "/etc", "C:\\Windows\\System32"],
    "deniedPatterns": ["rm -rf", "del /q", "format", "mkfs", "dd if=", "> /dev/"],
    "maxFileSize": 10485760,
    "maxExecutionTime": 30000
  }
}
